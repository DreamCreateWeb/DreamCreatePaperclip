# Database — Railway Postgres in production; docker-compose for local dev
# Local default (matches docker-compose.yml):
#   postgres://dream:dream@localhost:5432/dream_create
DATABASE_URL=postgres://dream:dream@localhost:5432/dream_create

# Stripe — billing + webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# $200/mo recurring price for the Dental Clinic Website (Dream Create) product.
# Live ID created 2026-05-08 (DRE-19): price_1TUvDtQ59dAubGMSkrqRZevL
STRIPE_PRICE_CLINIC_MONTHLY=price_1TUvDtQ59dAubGMSkrqRZevL

# GitHub — template instantiation (Octokit)
# PAT scoped to DreamCreateWeb org with `repo` and `workflow`
GITHUB_TOKEN=ghp_...
GITHUB_TEMPLATE_OWNER=DreamCreateWeb
GITHUB_TEMPLATE_REPO=DreamCreate-Master-Template

# Vercel — project create + deploy
VERCEL_TOKEN=
VERCEL_TEAM_ID=team_JCkmr9YSdUoHDEI9kLvznwCc

# Google Chat — ops alerts (DRE-12)
GOOGLE_CHAT_WEBHOOK=

# Admin auth — magic link session signing (DRE-18)
# Generate with: openssl rand -base64 48
ADMIN_SESSION_SECRET=replace-with-a-32-byte-random-string
# Comma-separated allowlist of operator emails. No entry => no admin access.
ADMIN_EMAILS=dustin@dreamcreate.web
# Resend (production email). If unset, magic links print to the server console.
RESEND_API_KEY=
ADMIN_LOGIN_EMAIL_FROM="Dream Create <admin@dreamcreate.web>"

# Slack — inbound DM bridge (DRE-35) + future CEO outbound
# SLACK_SIGNING_SECRET: Basic Information → App Credentials in api.slack.com/apps
# SLACK_BOT_TOKEN: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Vercel Blob — logo uploads (DRE-76)
# Auto-injected on Vercel; for local dev, create a Blob store and paste the token here.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Public site
NEXT_PUBLIC_APP_URL=http://localhost:3000
